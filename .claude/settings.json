{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs -d '\\n' npx eslint --fix 2>/dev/null || true",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs -d '\\n' npx prettier --write 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}
